# ─── Server Configuration ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_NAME=EconomicAnalytics
API_VERSION=1.0.0

# ─── Database ────────────────────────────────────────────────────────────────
# Use LOCAL_MONGODB_URI for local testing, MONGODB_URI for production
LOCAL_MONGODB_URI=mongodb://127.0.0.1:27017/economic_analytics
MONGODB_URI=mongodb://127.0.0.1:27017/economic_analytics

# ─── Security (REQUIRED) ─────────────────────────────────────────────────────
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use a weak value. NEVER commit your real .env to git.
JWT_SECRET=replace_this_with_a_long_random_secret_minimum_32_chars
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_secret

# JWT Expiration settings
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Seeding ─────────────────────────────────────────────────────────────────
# Optional: path to dataset JSON file for npm run seed
# Defaults to: backend/data/human_capital_project.json
# Override with: DATASET_PATH=/absolute/path/to/file.json npm run seed
DATASET_PATH=./data/human_capital_project.json
