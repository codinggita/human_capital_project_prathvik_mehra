# ─── Server Configuration ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_NAME=EconomicAnalytics

# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/economic_analytics

# ─── Security (REQUIRED) ─────────────────────────────────────────────────────
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER use a weak value. NEVER commit your real .env to git.
JWT_SECRET=replace_this_with_a_long_random_secret_minimum_32_chars

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000

# ─── Seeding ─────────────────────────────────────────────────────────────────
# Optional: path to dataset JSON file for npm run seed
# Defaults to: backend/data/human_capital_project.json
# Override with: DATASET_PATH=/absolute/path/to/file.json npm run seed
DATASET_PATH=./data/human_capital_project.json
