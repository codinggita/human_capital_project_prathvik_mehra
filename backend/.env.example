# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=MyBackend

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=dev
